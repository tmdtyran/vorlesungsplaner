{
	"name": "vorlesungsplaner",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.4.0",
	"scripts": {
		"dev": "bun --bun vite dev",
		"build": "bun --bun vite build",
		"import": "bun scripts/importLectures.ts",
		"preview": "bun --bun vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"catalog": "bun scripts/importCatalog.ts",
		"build:desktop-server": "bun scripts/build-desktop-server.ts --skip-neu-build",
		"build:desktop": "bun scripts/build-desktop-server.ts",
		"dev:desktop": "bun scripts/run-desktop-dev.ts"
	},
	"devDependencies": {
		"@neutralinojs/neu": "^11.7.2",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/vite": "^4.3.3",
		"@types/bun": "^1.3.14",
		"@types/node": "^24.13.3",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.21.0",
		"globals": "^17.7.0",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"svelte": "^5.56.6",
		"svelte-check": "^4.7.3",
		"tailwindcss": "^4.3.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"cheerio": "^1.2.0"
	}
}